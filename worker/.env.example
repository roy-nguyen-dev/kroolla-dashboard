SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Must match the key used by the client trigger (optional).
WORKER_API_KEY=

# Worker mode: inline | queue
WORKER_MODE=inline
MAX_CONCURRENT_JOBS=1

# Transcription config
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
TMP_DIR=.tmp
MAX_VIDEO_DURATION_SEC=10800
# Optional TikTok auth support:
# 1) Cookie file path (Netscape format), OR
# 2) Browser source, e.g. chrome or edge (optionally with profile: chrome:Default)
TIKTOK_COOKIES_FILE=
TIKTOK_COOKIES_FROM_BROWSER=

# Retry settings
DOWNLOAD_ATTEMPTS=3
TRANSCRIBE_ATTEMPTS=2
